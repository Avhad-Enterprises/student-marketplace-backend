{
  "compilerOptions": {
    /* ✅ File Structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* ✅ Module (IMPORTANT CHANGE) */
    "module": "commonjs",
    "target": "ES2020",

    /* ✅ Node Support */
    "lib": ["ES2020"],
    "types": ["node"],

    /* ✅ Path Alias (YOU ARE USING @/...) */
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    },

    /* ✅ Compatibility */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* ✅ Strictness */
    "strict": true,
    "skipLibCheck": true,

    /* ✅ Debugging */
    "sourceMap": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}