{
  "name": "student-marketplace-backend-v2",
  "version": "1.0.0",
  "description": "Backend API for Student Marketplace V2",
  "main": "src/server.ts",
  "scripts": {
    "start": "cross-env NODE_ENV=production node build/server.js",
    "dev": "cross-env NODE_ENV=development nodemon",
    "build": "tsc && tsc-alias",
    "test": "jest",
    "lint": "eslint --ignore-path .gitignore --ext .ts src/",
    "db:seed": "ts-node -r tsconfig-paths/register src/scripts/seed-data.ts",
    "db:clear": "ts-node -r tsconfig-paths/register src/scripts/clear-db.ts",
    "db:drop": "ts-node -r tsconfig-paths/register src/scripts/drop-tables.ts",
    "health": "ts-node -r tsconfig-paths/register src/scripts/health-check.ts",
    "db:test": "ts-node -r tsconfig-paths/register src/scripts/test-db-connection.ts",
    "api:test": "ts-node -r tsconfig-paths/register src/scripts/test-all-apis.ts",
    "migrate": "npx knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "npx knex migrate:rollback --knexfile knexfile.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.5",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.3",
    "envalid": "^7.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.0",
    "knex": "^2.4.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "papaparse": "^5.4.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.10.0",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^9.0.0",
    "winston": "^3.8.2",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/compression": "^1.7.2",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/hpp": "^0.2.2",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/morgan": "^1.9.4",
    "@types/node": "^18.19.130",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.3.14",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.1",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
